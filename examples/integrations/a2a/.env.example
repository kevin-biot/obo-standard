# Copy this file to .env and fill in values from keygen.py output.
# Never commit .env to version control.

# DNS name of the issuing operator (must match _obo-key DNS TXT record)
TRAVEL_AGENT_OPERATOR_ID=your-domain.com

# KYC-verified identifier for the acting agent/user (did:key or other DID)
TRAVEL_AGENT_PRINCIPAL_ID=did:key:z6MkhaXgBZDvotDkL5257faiztiGiC2QtKLGpbnnEGta2doK

# Ed25519 private key (base64 of PEM PKCS8) — from keygen.py output
TRAVEL_AGENT_PRIVATE_KEY_B64=<paste from keygen.py output>

# Ed25519 public key (base64url of raw 32 bytes) — from keygen.py output
# Used by FlightSearchAgent and SAPP to verify signatures
# In production: resolved from DNS _obo-key.<operator_id>
TRAVEL_AGENT_PUBKEY=<paste from keygen.py output>
